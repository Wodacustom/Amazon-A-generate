# Compose 项目名，会影响容器、网络和数据卷的前缀。
COMPOSE_PROJECT_NAME=aplus-agent

# 宿主机访问端口：前端 http://localhost:5173，后端 http://localhost:8002。
FRONTEND_PORT=5173
BACKEND_PORT=8002

# PostgreSQL 初始化配置；如果改了用户、密码或库名，也要同步修改 DATABASE_URL。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=aplus_agent

# 后端连接容器内 PostgreSQL 的地址；主机名 postgres 来自 docker-compose 服务名。
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/aplus_agent
REDIS_URL=redis://redis:6379/0

# RustFS S3 兼容对象存储。
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
S3_ENDPOINT_URL=http://rustfs:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_REGION=us-east-1
S3_BUCKET=aplus-agent

# 前端允许访问后端的来源；FRONTEND_PORT 变化时这里也要同步调整。
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# MVP 默认使用 mock，不填也能本地启动；接真实模型和 embedding 时再扩展 provider。
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-hash-v1
EMBEDDING_DIMENSIONS=8
LLM_PROVIDER=mock
LLM_MODEL=mock-a-plus-v1
