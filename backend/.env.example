# 应用名称和版本，会显示在 OpenAPI 与 /api/health 中。
APP_NAME=aplus-agent-api
APP_VERSION=0.1.0

# PostgreSQL 连接地址；本地直接运行后端时通常使用 127.0.0.1。
# 注意需要使用 async SQLAlchemy 驱动前缀 postgresql+asyncpg。
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/aplus_agent

# Redis 连接地址，用于缓存智能体运行进度等短期状态。
REDIS_URL=redis://localhost:6379/0

# JWT 与模型配置密钥。生产环境必须替换默认值。
JWT_SECRET_KEY=dev-secret-change-me
JWT_EXPIRE_MINUTES=1440
MODEL_CONFIG_SECRET_KEY=dev-model-config-secret-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# CORS 允许来源；前端开发端口变化时需要同步添加。
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:5175","http://127.0.0.1:5175","http://localhost:5176","http://127.0.0.1:5176"]

# RustFS/S3 兼容对象存储配置。
# S3_ENDPOINT_URL 是后端访问对象存储的地址。
S3_ENDPOINT_URL=http://127.0.0.1:9000

# 可选：生成预签名链接时使用的浏览器可访问地址。
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000

# 对象存储访问凭据；生产环境必须替换默认值。
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_REGION=us-east-1
S3_BUCKET=aplus-agent
