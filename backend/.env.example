APP_NAME=aplus-agent-api
APP_VERSION=0.1.0
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/aplus_agent
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:5175","http://127.0.0.1:5175","http://localhost:5176","http://127.0.0.1:5176"]
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_PUBLIC_BASE_URL=
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_REGION=us-east-1
S3_BUCKET=aplus-agent
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-hash-v1
EMBEDDING_DIMENSIONS=8
LLM_PROVIDER=mock
LLM_MODEL=mock-a-plus-v1
