APP_NAME=aplus-agent-api
APP_VERSION=0.1.0
DATABASE_URL=mysql+aiomysql://root:password@127.0.0.1:3306/aplus_agent?charset=utf8mb4
REDIS_URL=redis://localhost:6379/0
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:5175","http://127.0.0.1:5175","http://localhost:5176","http://127.0.0.1:5176"]
SCENE_AGENT_PROVIDER=rule
PRODUCT_INFO_AGENT_PROVIDER=rule
GENERATION_AGENT_PROVIDER=mock
IMAGE_GENERATION_PROVIDER=mock
DEFAULT_IMAGE_MODEL=nanobanana_pro
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-plus
DASHSCOPE_TIMEOUT_SECONDS=20
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3-pro-image
GEMINI_TIMEOUT_SECONDS=120
