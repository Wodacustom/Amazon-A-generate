* text=auto

# Source files use LF across platforms.
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.scss text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell scripts should stay executable-friendly.
*.sh text eol=lf

# Windows scripts may keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets.
*.gif binary
*.ico binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.png binary
*.webp binary
*.zip binary

